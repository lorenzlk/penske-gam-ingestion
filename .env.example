# Required: ID from the Sheet URL (.../d/<THIS_PART>/edit)
# Penske KVP GAM: https://docs.google.com/spreadsheets/d/1TDZGpXNrQ7qoH9oePzx0KKSrBKY3iHYXIcG_5AN9VRE/edit?gid=0#gid=0
GAM_SPREADSHEET_ID=1TDZGpXNrQ7qoH9oePzx0KKSrBKY3iHYXIcG_5AN9VRE

# Tab name (must match the sheet tab in the UI; create the tab if it does not exist)
GAM_SHEET_TAB=Data

# Gmail search query used to find each report message (tune to your inbox).
# Example subject line (weekly date span changes): 
#   Mula Inc Mail - Report_ PMC _ Mula Report Apr 30 – May 6, 2026
# Phrase that matches Gmail web search (same as typing quotes around PMC _ Mula Report):
GAM_GMAIL_QUERY="\"PMC _ Mula Report\" has:attachment newer_than:180d in:anywhere"
# Alternative subject-only:
# GAM_GMAIL_QUERY=subject:"PMC _ Mula Report"

# Label applied after a message is successfully appended (prevents duplicates)
GAM_PROCESSED_LABEL=GAM/Ingested

# OAuth paths (download Desktop client JSON from Google Cloud Console)
GOOGLE_OAUTH_CLIENT_SECRETS=credentials.json
GOOGLE_OAUTH_TOKEN=token.json

# Optional: regex to pick one attachment when multiple CSVs exist (Python re syntax)
# Penske PMC Mula export attachment name is typically "PMC _ Mula Report.csv"
GAM_ATTACHMENT_REGEX=PMC\s+_\s+Mula\s+Report\.csv

# Optional: Excel-exported CSV often needs utf-8-sig (default)
# GAM_CSV_ENCODING=utf-8-sig

# Optional: set to 1 to log actions without writing Sheets or applying labels
# GAM_DRY_RUN=0
